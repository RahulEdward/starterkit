# Best-Option Environment Configuration

# Database
DATABASE_URL=sqlite:///./best_option.db

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000

# Security (REQUIRED - Generate using: python -c "import secrets; print(secrets.token_hex(32))")
API_KEY_PEPPER=your_64_character_hex_string_here

# Application Settings
DEBUG=True
LOG_LEVEL=INFO

# Note: Broker API keys are stored in database per user, not in .env
# Each user provides their own broker credentials during registration
